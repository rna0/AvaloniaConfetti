# Canvas-confetti style configuration
# See https://github.com/catdad/canvas-confetti

# Emission settings
PARTICLE_COUNT=50
ANGLE=90
SPREAD=90
START_VELOCITY=55
CONFETTI_PER_SECOND=70

# Physics
DECAY=0.94
GRAVITY=0.6
DRIFT=0

# Lifecycle (frames before particle fades)
TICKS=350

# Appearance
SCALAR=1.5
FLAT=False

# Shapes: square, circle, star (comma-separated)
SHAPES=square,circle

# Origin (0-1, normalized screen coordinates)
ORIGIN_X=0.5
ORIGIN_Y=0.8

# Colors (comma-separated hex values)
COLORS=#26ccff,#a25afd,#ff5e7e,#88ff5a,#fcff42,#ffa62d,#ff36ff